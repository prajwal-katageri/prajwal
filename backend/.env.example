# Copy this file to .env and fill values
# IMPORTANT: If your password has special characters, URL-encode it.

# MongoDB Atlas (recommended)
# Example:
# MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER_HOST/bizcare?retryWrites=true&w=majority
MONGODB_URI=

# Express session secret (set to a long random string)
SESSION_SECRET=

# Optional
PORT=3000
